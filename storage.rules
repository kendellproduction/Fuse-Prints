rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isValidImageUpload() {
      return request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /products/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    match /gallery/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    match /hero/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    match /site-images/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }
  }
}
